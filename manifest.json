{
  "manifest_version": 3,
  "name": "Job Search Lens",
  "short_name": "Job Lens",
  "description": "Local-only Chrome extension for LinkedIn Jobs that can optionally highlight saved keywords on any website.",
  "version": "1.3.0",
  "version_name": "1.3.0",
  "permissions": ["contextMenus", "storage", "activeTab", "permissions", "scripting"],
  "host_permissions": ["https://www.linkedin.com/*"],
  "optional_host_permissions": ["http://*/*", "https://*/*"],
  "homepage_url": "https://madhushanandawaththa.github.io/jslens/",
  "minimum_chrome_version": "114",
  "icons": {
    "16": "assets/icons/icon16.png",
    "32": "assets/icons/icon32.png",
    "48": "assets/icons/icon48.png",
    "128": "assets/icons/icon128.png"
  },
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "Job Search Lens",
    "default_icon": {
      "16": "assets/icons/icon16.png",
      "32": "assets/icons/icon32.png"
    },
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": ["https://www.linkedin.com/*"],
      "js": ["shared.js", "dom-heuristics.js", "content.js"],
      "css": ["styles.css"],
      "run_at": "document_idle"
    }
  ],
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'"
  }
}
