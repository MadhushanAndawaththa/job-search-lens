{
  "manifest_version": 3,
  "name": "Job Hunt Visualizer",
  "description": "Local-first LinkedIn helper that highlights selected keywords and fades jobs you have already viewed.",
  "version": "1.0.0",
  "permissions": ["contextMenus", "storage", "tabs"],
  "host_permissions": [
    "https://www.linkedin.com/*",
    "https://linkedin.com/*",
    "https://*.linkedin.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "Job Hunt Visualizer",
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": [
        "https://www.linkedin.com/*",
        "https://linkedin.com/*",
        "https://*.linkedin.com/*"
      ],
      "js": ["shared.js", "content.js"],
      "css": ["styles.css"],
      "run_at": "document_idle"
    }
  ]
}