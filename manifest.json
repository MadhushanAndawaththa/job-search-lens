{
  "manifest_version": 3,
  "name": "Job Search Lens",
  "short_name": "Job Lens",
  "description": "Local-only Chrome extension that highlights keywords on any website and adds LinkedIn Jobs tools.",
  "version": "1.3.0",
  "permissions": ["contextMenus", "storage", "tabs"],
  "host_permissions": ["http://*/*", "https://*/*"],
  "homepage_url": "https://madhushanandawaththa.github.io/Job_Search/",
  "minimum_chrome_version": "114",
  "icons": {
    "16": "assets/icons/icon16.png",
    "32": "assets/icons/icon32.png",
    "48": "assets/icons/icon48.png",
    "128": "assets/icons/icon128.png"
  },
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "Job Search Lens",
    "default_icon": {
      "16": "assets/icons/icon16.png",
      "32": "assets/icons/icon32.png"
    },
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": ["http://*/*", "https://*/*"],
      "js": ["shared.js", "dom-heuristics.js", "content.js"],
      "css": ["styles.css"],
      "run_at": "document_idle"
    }
  ]
}